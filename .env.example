# =============================================================================
# ChickenFifa — Variables de entorno
# Copiar a .env y completar los valores. NUNCA commitear .env al repositorio.
# =============================================================================

# --- Django Core ---
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.local

# --- Base de datos (PostgreSQL) ---
# Formato: postgres://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=postgres://chickenfifa:chickenfifa_pass@localhost:5432/chickenfifa_db
CONN_MAX_AGE=60

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0

# --- Lógica del torneo ---
# Minutos antes del partido en que se bloquean los pronósticos
PREDICTION_LOCK_MINUTES=30

# --- Email (producción) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password
DEFAULT_FROM_EMAIL=noreply@chickenfifa.com

# --- Sentry (opcional, solo producción) ---
SENTRY_DSN=

# --- OCI (solo para CI/CD en GitHub Actions) ---
# Estos se configuran como Secrets en GitHub, no en el archivo .env local
# OCI_CLI_USER=
# OCI_CLI_TENANCY=
# OCI_CLI_FINGERPRINT=
# OCI_CLI_KEY_CONTENT=
# OCI_CLI_REGION=
# OCI_REGISTRY=<region>.ocir.io
# OCI_NAMESPACE=
# OCI_REPO_NAME=chickenfifa
# OCI_INSTANCE_IP=
# OCI_SSH_PRIVATE_KEY=
